# Normalize all text files to LF in the repo.
# The pipeline (Docker build, Jenkins `sh` steps, Terraform) runs on Linux,
# so CRLF line endings from Windows checkouts must never reach it.
* text=auto eol=lf

# Be explicit for the files that are executed on Linux.
*.py        text eol=lf
*.sh        text eol=lf
*.tf        text eol=lf
Dockerfile  text eol=lf
Jenkinsfile text eol=lf
